{
  "manifest_version": 3,
  "name": "Myma NotebookLM Cookie Sync",
  "version": "0.2.0",
  "description": "Sincroniza cookies de Google del browser al backend Myma para mantener viva la sesion NotebookLM sin re-pegar cookies manualmente.",
  "key": "",
  "permissions": ["cookies", "alarms", "storage"],
  "host_permissions": ["https://*.google.com/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "externally_connectable": {
    "matches": [
      "https://aplicaciones-myma.onrender.com/*",
      "https://app.myma.cl/*",
      "https://*.myma.cl/*",
      "http://localhost:3001/*",
      "http://localhost:5173/*",
      "http://127.0.0.1:3001/*",
      "http://127.0.0.1:5173/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Myma NotebookLM Cookie Sync"
  }
}
